# Backend Service Configuration

# Server port
PORT=3000

# External API base URL for notification service
EXTERNAL_API_BASE=http://4.224.186.213/evaluation-service

# Bearer token for external API authentication
BEARER_TOKEN=

# Maximum retry attempts for failed API calls
MAX_RETRIES=2

# Logging service URL
LOGGING_SERVICE_URL=http://localhost:3001/logs

# Node environment
NODE_ENV=development

# Cache timeout in milliseconds (default: 5 minutes)
CACHE_TIMEOUT=300000
